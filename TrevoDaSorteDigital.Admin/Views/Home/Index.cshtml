    function ObterResultadosLotoMania() {
        $('#resultadoLotoMania').empty();
        const xhr = new XMLHttpRequest();
        xhr.open("post", "https://api.trevodasortedigital.com.br/Loterias/BuscarResultadoPorUltimoConcurso?loteria=lotomania");
        xhr.send();
        xhr.responseType = "json";
        xhr.onload = () => {
            if (xhr.readyState == 4 && xhr.status == 200) {
                var resposta = xhr.response;
                var tagHtml = "<p><b style='color:#f78100;font-weight:bold'>Concurso: </b>" + resposta.concurso + " <b style='color:#f78100;font-weight:bold'>Data Sorteio: </b>" + resposta.data + "</p>"
                tagHtml += "<p style = 'color:#f78100;font-weight:bold'>Números Sorteados</p>";
                tagHtml += "<p>";
                var contador = 0;

                $(resposta.dezenas).each(function () {
                    contador = contador + 1;

                    if (contador >= 1 && contador <= 10) {
                        tagHtml += this + " ";

                        if (contador === 10) {
                            tagHtml += "<br />"
                        }
                    }
                    if (contador >= 11 && contador <= 20) {
                        tagHtml += this + " ";

                        if (contador === 10) {
                            tagHtml += "<br />"
                        }
                    }
                });

                tagHtml += "</p>";
