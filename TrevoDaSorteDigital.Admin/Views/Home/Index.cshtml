@{
    ViewBag.Title = "Home Page";
}

<style>
    table {
        border-collapse: separate;
        border: solid black 1px;
        border-radius: 6px;
    }

    td, th {
        border-left: solid black 1px;
        border-top: solid black 1px;
    }

    th {
        background-color: blue;
        border-top: none;
    }

        td:first-child, th:first-child {
            border-left: none;
        }
</style>
<script>
    $(function () {
        var modal = document.getElementById("mLoading");
        modal.style.display = "block";

        ObterResultadosMaisMilionaria();
        ObterResultadosMegaSena();
        ObterResultadosLotoFacil();
        ObterResultadosQuina();
        ObterResultadosLotoMania();
        ObterResultadosTimeMania();
        ObterResultadosDuplaSena();
        ObterResultadosDiaDeSorte();
        ObterResultadosSuperSete();

        window.setTimeout(function () {
            modal.style.display = "none";
        },2000);
    });

    function ObterResultadosMaisMilionaria() {
        $('#resultadoMaisMilionaria').empty();
        const xhr = new XMLHttpRequest();
        xhr.open("post", "https://api.trevodasortedigital.com.br/Loterias/BuscarResultadoPorUltimoConcurso?loteria=maismilionaria");
        xhr.send();
        xhr.responseType = "json";
        xhr.onload = () => {
            if (xhr.readyState == 4 && xhr.status == 200) {
                var resposta = xhr.response;
                var tagHtml = "<p><b style='color:#101451;font-weight:bold'>Concurso: </b>" + resposta.concurso + " <b style='color:#101451;font-weight:bold'>Data Sorteio: </b>" + resposta.data + "</p>"
                tagHtml += "<p style = 'color:#101451;font-weight:bold'>Números Sorteados</p>";
                tagHtml += "<p>";
                $(resposta.dezenas).each(function () {
                    tagHtml += this + " ";
                });
                tagHtml += "</p>";

                tagHtml += "<p style = 'color:#101451;font-weight:bold'>Trevos</p>";
                tagHtml += "<p>";
                $(resposta.trevos).each(function () {
                    tagHtml += this + " ";
                });
                tagHtml += "</p>";
                tagHtml += "<p><b style='color:#101451;font-weight:bold'>Próximo Concurso: </b>" + resposta.proximoConcurso + " <b style='color:#101451;font-weight:bold'><br />Data Próximo Sorteio: </b>" + resposta.dataProximoConcurso + "</p>"

                $('#resultadoMaisMilionaria').html(tagHtml);

            } else {
                console.log(`Error: ${xhr.status}`);
            }
        };
    }

